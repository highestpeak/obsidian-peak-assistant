		"autoprefixer": "^10.4.16",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.27.0",
		"esbuild-plugin-alias": "^0.2.1",
		"npm-run-all": "^4.1.5",
		"obsidian": "latest",
		"postcss": "^8.4.32",
		"tailwindcss": "^3.4.1",
