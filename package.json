		"@streamdown/code": "^1.0.3",
		"@streamdown/math": "^1.0.2",
		"@streamdown/mermaid": "^1.0.2",
		"@uiw/react-codemirror": "^4.25.4",
		"@xyflow/react": "^12.10.0",
		"ai": "^6.0.175",
		"ai-elements": "^1.6.3",
