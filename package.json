{
	"name": "obsidian-peak-assistant",
	"version": "1.0.0",
	"description": "Peak Assistant is a plugin for Obsidian (https://obsidian.md) that allows you to use AI to help you with your notes.",
	"main": "main.js",
	"scripts": {
		"dev:tailwind": "npx tailwindcss -i src/styles/tailwind.css -o styles.tailwind.css --watch",
		"dev:streamdown": "npx tailwindcss -i src/styles/streamdown.css -o styles.streamdown.css --config tailwind.streamdown.config.js --watch",
		"dev:css": "node scripts/concat-css.mjs watch",
		"dev:ts": "npm run copy-sdk && node esbuild.config.mjs",
		"dev": "npm-run-all --parallel dev:tailwind dev:streamdown dev:css dev:ts",
		"predev:desktop": "npm run build:css",
		"dev:desktop": "vite",
		"build:tailwind": "npx tailwindcss -i src/styles/tailwind.css -o styles.tailwind.css --minify",
		"build:streamdown": "npx tailwindcss -i src/styles/streamdown.css -o styles.streamdown.css --config tailwind.streamdown.config.js --minify",
		"build:css": "npm run build:tailwind && npm run build:streamdown && node scripts/concat-css.mjs",
		"check:bundle": "node --check main.js",
		"copy-sdk": "node scripts/copy-agent-sdk.mjs",
		"build": "npm run build:css && node esbuild.config.mjs production && npm run check:bundle && npm run copy-sdk",
		"build:desktop": "vite build",
		"test": "node run-test.js",
		"trace": "node run-test.js scripts/run-agent.ts",
		"trace:latest": "node run-test.js scripts/trace-latest.ts",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"install-safe": "npm install --legacy-peer-deps",
		"postinstall": "echo 'Dependencies installed successfully. Run \"npm run build\" to build the project.'"
	},
	"keywords": [],
	"author": "",
	"license": "GPL-3.0",
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.74",
		"@ai-sdk/google": "^3.0.67",
		"@ai-sdk/openai": "^3.0.60",
		"@ai-sdk/perplexity": "^3.0.32",
		"@anthropic-ai/claude-agent-sdk": "^0.2.101",
		"@codemirror/state": "^6.5.3",
		"@codemirror/view": "^6.39.9",
		"@dagrejs/dagre": "^3.0.0",
		"@langchain/community": "^1.1.3",
		"@langchain/core": "^1.1.8",
		"@langchain/textsplitters": "^1.0.1",
		"@openrouter/ai-sdk-provider": "^2.9.0",
